# LiveJasmin model feed
# The app ships with the known working LiveJasmin feed defaults from the existing projects.
# Set these values when you need to override credentials, category, or endpoint per environment.
LIVEJASMIN_FEED_URL=https://atwmcd.com/api/model/feed
LIVEJASMIN_FEED_ACCESS_KEY=
LIVEJASMIN_FEED_PS_ID=affil28
LIVEJASMIN_FEED_SITE_ID=jsm
LIVEJASMIN_FEED_CATEGORY=girl
LIVEJASMIN_FEED_IMAGE_SIZES=320x240,800x600
LIVEJASMIN_FEED_EXTENDED_DETAILS=1
LIVEJASMIN_FEED_SHOW_OFFLINE=0

# Optional bearer token support for alternate feed gateways.
LIVEJASMIN_FEED_TOKEN=
